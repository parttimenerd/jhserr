{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^-{10,}\\s+[A-Z](?:\\s+[A-Z])+\\s+-{10,}$",
      "end": "^-{10,}\\s+[A-Z](?:\\s+[A-Z])+\\s+-{10,}$|^END\\.$"
    }
  },
  "wordPattern": "(?:0x[0-9a-fA-F]+|[\\w$.]+(?:@[\\w.]+)?)"
}
